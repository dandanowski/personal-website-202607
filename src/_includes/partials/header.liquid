<header class="site-header">
  <div class="wrap bar">
    <a class="brand" href="/"><strong>{{ site.name }}</strong><span>{{ site.role }}</span></a>
    <nav class="nav">
      <a href="/work/"{% if page.url contains "/work" %} aria-current="page"{% endif %}>work</a>
      <a href="/writing/"{% if page.url contains "/writing" or page.url contains "/wrote-about" %} aria-current="page"{% endif %}>writing</a>
      <a href="/lab/"{% if page.url contains "/lab" %} aria-current="page"{% endif %}>lab</a>
      <a href="/cv/"{% if page.url contains "/cv" %} aria-current="page"{% endif %}>cv</a>
      <a href="/#about" class="hide-sm">about</a>
      <a href="/#contact">contact</a>
      <div class="theme-toggle" id="theme-toggle" role="radiogroup" aria-label="Colour theme">
        <label aria-label="Match system theme">
          <input type="radio" name="theme" value="auto" checked>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="12" rx="1.5"/><path d="M8 20h8M12 16v4"/></svg>
        </label>
        <label aria-label="Light theme">
          <input type="radio" name="theme" value="light">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4.2"/><path d="M12 2.5v2M12 19.5v2M2.5 12h2M19.5 12h2M5.1 5.1l1.4 1.4M17.5 17.5l1.4 1.4M18.9 5.1l-1.4 1.4M6.5 17.5l-1.4 1.4"/></svg>
        </label>
        <label aria-label="Dark theme">
          <input type="radio" name="theme" value="dark">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M15.5 2.2A9 9 0 1 0 21.8 16 7.2 7.2 0 0 1 15.5 2.2z"/></svg>
        </label>
      </div>
    </nav>
  </div>
</header>
