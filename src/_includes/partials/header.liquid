<header class="site-header">
  <div class="wrap bar">
    <a class="brand" href="/"><strong>{{ site.name }}</strong><span>{{ site.role }}</span></a>
    <nav class="nav">
      <a href="/#work">work</a>
      <a href="/writing/"{% if page.url contains "/writing" or page.url contains "/wrote-about" %} aria-current="page"{% endif %}>writing</a>
      <a href="/cv/"{% if page.url contains "/cv" %} aria-current="page"{% endif %}>cv</a>
      <a href="/#about" class="hide-sm">about</a>
      <a href="/#contact">contact</a>
      <button class="theme-toggle" type="button" aria-label="Toggle colour theme">
        <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4.2"/><path d="M12 2.5v2M12 19.5v2M2.5 12h2M19.5 12h2M5.1 5.1l1.4 1.4M17.5 17.5l1.4 1.4M18.9 5.1l-1.4 1.4M6.5 17.5l-1.4 1.4"/></svg>
        <svg class="moon" viewBox="0 0 24 24" fill="currentColor"><path d="M15.5 2.2A9 9 0 1 0 21.8 16 7.2 7.2 0 0 1 15.5 2.2z"/></svg>
      </button>
    </nav>
  </div>
</header>
